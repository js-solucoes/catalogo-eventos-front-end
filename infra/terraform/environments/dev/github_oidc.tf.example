# Opcional: copie para github_oidc.tf e ajuste github_org / github_repo.
# Aplica a role de deploy com trust restrito à branch main (padrão do módulo).
#
# Se o OIDC provider "token.actions.githubusercontent.com" JÁ existir na conta
# (criação manual anterior), defina create_oidc_provider = false.
#
# Para permitir deploy a partir de qualquer branch (só laboratório):
#   allow_all_branches = true
#
# Para outra branch fixa:
#   allowed_ref_pattern = "repo:ORG/REPO:ref:refs/heads/nome-da-branch"

